# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@domain.com
# Multiple recipients separated by commas (no spaces around commas)
SMTP_TO=recipient1@domain.com,recipient2@domain.com,recipient3@domain.com

# Application Configuration
JOB_LOCATIONS=90009885,90009888
CRON_SCHEDULE=0 */1 * * *
RUN_ON_STARTUP=true
CV_PATH=CV_Vasiliki Ploumistou_22_05.pdf
DATA_DIR=data
OUTPUT_DIR=.
MAX_JOBS_PER_LOCATION=1000

# Final Validation Configuration
# Set to false to skip the final LLM validation step before sending email notifications
# When disabled, jobs will be sent for notification immediately after CV-based evaluation
ENABLE_FINAL_VALIDATION=true

# Rate Limiting Configuration
# Based on Groq's API limits (as of July 2024):
# - Requests: 14,400 per day (free tier)
# - Tokens: 6,000 per minute (free tier)
# Conservative settings recommended to avoid hitting limits:
MAX_REQUESTS_PER_MINUTE=10
MAX_TOKENS_PER_MINUTE=5800

# Google Cloud Storage Configuration
# Set GCS_ENABLED=true to enable cloud storage for logs, data, and checkpoints
GCS_ENABLED=false
GCS_BUCKET_NAME=your-job-scorer-bucket
GCS_PROJECT_ID=your-gcp-project-id
GCS_FALLBACK_DIR=gcs_fallback