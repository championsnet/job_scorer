# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional: override endpoint for compatible providers
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# Optional: path to policy JSON file with all filters/prompts/thresholds/templates
POLICY_CONFIG_PATH=config/config.json

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@domain.com
# Multiple recipients separated by commas (no spaces around commas)
SMTP_TO=recipient1@domain.com,recipient2@domain.com,recipient3@domain.com

# Application Configuration
# Deprecated fallback override. Prefer setting `app.jobLocations` in config/config.json.
# JOB_LOCATIONS=10000000,20000000
# Deprecated fallback override. Prefer setting `app.cronSchedule` in config/config.json.
# CRON_SCHEDULE=0 */1 * * *
RUN_ON_STARTUP=true
# In dev mode (Air/DEV_MODE), run job every N minutes. Default: 5. Set to 0 to disable dev cron.
# DEV_CRON_INTERVAL_MINUTES=60
# Deprecated fallback override. Prefer setting `cv.path` in config/config.json.
# CV_PATH=your_cv.pdf
DATA_DIR=data
OUTPUT_DIR=.
MAX_JOBS_PER_LOCATION=1000
# Optional: enable UniPDF parser when licensed
ENABLE_UNIPDF=false
UNIPDF_LICENSE_KEY=

# Rate Limiting Configuration
# Conservative settings recommended to avoid hitting limits:
MAX_REQUESTS_PER_MINUTE=10
MAX_TOKENS_PER_MINUTE=5800

# Google Cloud Storage Configuration
# Set GCS_ENABLED=true to enable cloud storage for logs, data, and checkpoints
GCS_ENABLED=false
GCS_BUCKET_NAME=your-job-scorer-bucket
GCS_PROJECT_ID=your-gcp-project-id
GCS_FALLBACK_DIR=gcs_fallback

# --- Multi-tenant runtime modes ---
# APP_MODE can be:
# - legacy (default): existing single-user mode
# - web: multi-tenant API + SPA service
# - worker: private Cloud Tasks worker
# - import: import local legacy data into Firestore
APP_MODE=legacy

# Multi-tenant auth
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_FILE=
# Dev-only bypass mode. When true, send Authorization: Bearer dev:you@example.com
AUTH_BYPASS=false

# Worker / scheduler internal auth
WORKER_TOKEN=replace-with-random-token
SCHEDULER_TOKEN=replace-with-random-token

# Queueing
CLOUD_TASKS_PROJECT_ID=your-gcp-project-id
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=job-scorer-runs
CLOUD_TASKS_WORKER_URL=https://job-scorer-worker-xxxxx.run.app
# Optional OIDC task invoker service account
CLOUD_TASKS_SERVICE_ACCOUNT=

# Billing
RUN_CREDIT_COST=1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_CREDITS=25
STRIPE_SUCCESS_URL=https://your-frontend.example.com/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://your-frontend.example.com/billing/cancel
# Optional richer package definition
# BILLING_PACKAGES_JSON=[{"id":"starter","name":"Starter","description":"25 credits","credits":25,"price_id":"price_xxx"}]

# Frontend static bundle location (inside container by default)
FRONTEND_DIST_DIR=frontend/dist

# --- Frontend Firebase config (local dev only) ---
# For local frontend development, copy these to frontend/.env
# For production deployments, export as env vars before running deploy_release.sh
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
