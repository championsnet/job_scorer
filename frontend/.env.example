# Leave empty for local dev (Vite proxy handles /api -> localhost:8008)
# Only set for production builds or when bypassing the Vite proxy
VITE_API_URL=

# Firebase client config (required for real auth mode)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
